# ---------------------------------------------------------------------------
# GUImorph .gitignore
#
# Policy (Phase 0 cleanup):
#  - Visual Studio IDE caches & build-output dirs are NEVER tracked.
#  - Release artifacts WE produce (tkogl2.dll/.lib/.exp/.pdb, *.obj) are NOT
#    tracked.
#  - Third-party BUILD INPUTS are intentionally still tracked (Tcl/Tk stub
#    libs, glut*, OpenGL32.lib, etc.) so a build still has its dependencies.
#  - VS project/solution files (.sln/.vcxproj*) are kept for reference.
# ---------------------------------------------------------------------------

# --- Large archives / media ---
zips/
*.zip
*.mp4

# --- Node (tooling only) ---
node_modules/

# ===========================================================================
# Visual Studio / MSBuild IDE caches (safe to delete; never track)
# ===========================================================================
.vs/
*.diagsession
*.tlog
*.VC.db
*.VC.opendb
*.opensdf
*.sdf
*.suo
*.aps
*.ncb
*.cache

# ===========================================================================
# VS build output / intermediate directories
# (Scoped to the C-project build dirs so we do NOT match inst/libs/x64,
#  which holds vendored third-party DLLs we keep.)
# ===========================================================================
integrated-guimorph-development_EOC/Project/tkogl2/Debug/
integrated-guimorph-development_EOC/Project/tkogl2/[Rr]elease/
integrated-guimorph-development_EOC/Project/tkogl2/x64/
integrated-guimorph-development_EOC/Project/tkogl2/Win32/
integrated-guimorph-development_EOC/Standalone/**/Debug/
integrated-guimorph-development_EOC/Standalone/**/[Rr]elease/
integrated-guimorph-development_EOC/Standalone/**/x64/
integrated-guimorph-development_EOC/Standalone/**/Win32/

# --- CMake build directories ---
build/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake

# macOS CMake build trees (generated proof artifacts; deployed copies live in
# inst/libs, mirroring the Windows tkogl2.dll policy). Never tracked.
integrated-guimorph-development_EOC/Project/tkogl2/build-gate/
integrated-guimorph-development_EOC/Project/tkogl2/test/gate/build-gate/
integrated-guimorph-development_EOC/Project/tkogl2/build-mac/

# --- Compiler intermediates (anywhere) ---
*.obj
*.o
*.ilk
*.idb
*.ipch
*.pch
*.res

# ===========================================================================
# Release artifacts WE build (do NOT track).
# Named explicitly so vendored third-party .dll/.lib are still tracked.
# ===========================================================================
tkogl2.dll
tkogl2_old.dll
tkogl2.lib
tkogl2.exp
tkogl2.pdb
*.pdb

# RND-02 direct-mode Tk import lib, generated on Windows from R's tk86.dll.
# Regenerable via lib /def:tk86.def (recipe in
# .planning/todos/pending/phase-02-windows-validation.md); not tracked.
tk86.lib
tk86.def
tk86.exp

# ===========================================================================
# R / RStudio session cruft
# ===========================================================================
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# ===========================================================================
# OS cruft
# ===========================================================================
.DS_Store
Thumbs.db
desktop.ini

# ===========================================================================
# Editor / agent local files (Cursor + GSD planning)
# ===========================================================================

# ===========================================================================
# MSVC CMake build tree (build/ is ignored above; this is the VS generator path)
# ===========================================================================
build-msvc/
.r-lib/

# ===========================================================================
# DLL / source backups and ad-hoc test deploys
# ===========================================================================
*.dll.bak
*.dll.phase*-test
*.dll.pre-phase*.bak
*.c.bak

# ===========================================================================
# Build / verification logs (not source)
# ===========================================================================
build-phase7.log
**/build.log
renv-check-out.txt

# ===========================================================================
# Repo temp artifacts (Windows + one-off automation)
# ===========================================================================
.tmp-*
nul

# ===========================================================================
# Ad-hoc helper scripts (tracked scripts: deploy-dll.ps1, init-renv.R, etc.)
# ===========================================================================
scripts/_*.sh
scripts/.phase*

# ===========================================================================
# Scratch / local test files
# ===========================================================================
_load_test.R
.Rproj.user

# local build and edit artifacts
*.bak
*.bak2
*.bak3
*.orig-bak
*.WORKING-*
*.mesh-validatedot-ok
fixes/
build-msvc/

test_data/

# --- edit/patcher backups (anything containing 'bak') ---
*bak*

# --- machine-specific template (regenerated per project) ---
integrated-guimorph-development_EOC/Project/GUImorphDevelopment/template.txt

# ===========================================================================
# Build artifacts that must never be committed
# ===========================================================================
*.tar.gz
*.Rcheck/
